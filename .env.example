# Required — Algolia search index credentials
NEXT_PUBLIC_ALGOLIA_APP_ID=your-app-id
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=your-search-only-api-key
ALGOLIA_ADMIN_KEY=your-admin-api-key

# Required (v2) — PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Optional — GitHub integration for "Edit this page" links
GITHUB_REPO=acme-corp/docs
GITHUB_BRANCH=main
GITHUB_TOKEN=your-fine-grained-pat

# Optional — User feedback endpoint
FEEDBACK_API_URL=https://api.acme.example/docs-feedback
FEEDBACK_API_KEY=

# Internal — set by CI, do not commit real values
DEPLOY_TOKEN=
REGISTRY_PASSWORD=
SLACK_WEBHOOK_URL=
